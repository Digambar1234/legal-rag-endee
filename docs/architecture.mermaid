graph TB
    subgraph INPUT["📄 Document Input"]
        A[PDF / DOCX / TXT Files]
    end

    subgraph PROCESSING["⚙️ Processing Pipeline"]
        B[Document Loader]
        C[Text Chunker\nmax=800 chars, overlap=150]
        D[Embedding Engine\nall-MiniLM-L6-v2\n384 dimensions]
    end

    subgraph ENDEE["🗄️ Endee Vector Database"]
        E[(Endee Index\nHNSW + Cosine Similarity\nup to 1B vectors)]
    end

    subgraph QUERY["🔍 Query Pipeline"]
        F[User Question]
        G[Query Embedding\n384-dim vector]
        H[ANN Search in Endee\nTop-K Results]
        I[Answer Generator\nContext-grounded]
    end

    subgraph OUTPUT["💡 Output Layer"]
        J[Streamlit UI]
        K[FastAPI REST API]
        L[CLI Tool]
    end

    A --> B --> C --> D --> E
    F --> G --> H
    E --> H --> I
    I --> J
    I --> K
    I --> L
